@import "styles/legal-doc.wxss";

page {
  background: #f5f7fa;
  color: #17212b;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.detail-page {
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.page-tab {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.section-title {
  margin: 32rpx 0 16rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #17212b;
}

/* 卡片内 / 详情子区：紧凑一级标题 */
.section-title.compact {
  margin: 0 0 8rpx;
  font-size: 30rpx;
}

/* Tab 页 MECE 模块：柔和二级标题（我的页等） */
.section-title.subtle {
  margin: 20rpx 0 6rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #68717d;
  letter-spacing: 1rpx;
}

.section-desc {
  margin: 0 0 12rpx;
  padding-left: 4rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #9aa3ad;
}

.page-block {
  margin-bottom: 8rpx;
}

/* 详情页区块（与 section-title 同级语义） */
.res-section {
  margin-bottom: 8rpx;
}

.res-section-head {
  margin: 24rpx 0 12rpx;
  padding-left: 4rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #17212b;
}

.owner-subsection-head {
  margin: 0 0 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #47515c;
}

/* 表单卡片内分组标题 */
.form-section {
  margin: 8rpx 0 16rpx;
  padding-top: 20rpx;
  color: #176b5b;
  font-size: 30rpx;
  font-weight: 800;
  border-top: 2rpx solid #f0f2f5;
}

.form-card .form-section:first-child {
  margin-top: 0;
  padding-top: 0;
  border-top: none;
}

/* 深色页头（记录 / 审核 / 流程说明共用） */
.hero-card {
  margin-bottom: 16rpx;
  padding: 32rpx 28rpx;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #101820 0%, #1a3a35 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(16, 24, 32, 0.12);
}

.hero-kicker {
  color: #7bd7c0;
  font-size: 24rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.3;
}

.hero-text {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.55;
  color: #d8e1e8;
}

.hero-status {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 8rpx 14rpx;
  border-radius: 6rpx;
  background: rgba(255, 241, 223, 0.18);
  color: #ffd2a1;
  font-size: 24rpx;
  font-weight: 700;
}

.hero-time {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.copyable-id {
  word-break: break-all;
}

.trade-id-line {
  word-break: break-all;
}

.empty.empty-inline {
  padding: 32rpx 20rpx;
  text-align: left;
  font-size: 26rpx;
  line-height: 1.55;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 32rpx 0 16rpx;
}

.section-title.inline {
  margin: 0;
}

.section-link {
  color: #176b5b;
  font-size: 26rpx;
  font-weight: 700;
}

.muted {
  color: #68717d;
}

.card {
  margin-bottom: 16rpx;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(23, 33, 43, 0.06);
  box-sizing: border-box;
}

.tag {
  display: inline-flex;
  align-items: center;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  background: #e9f5f1;
  color: #176b5b;
  font-size: 24rpx;
}

.button-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 8rpx;
  background: #176b5b;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.button-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border: 2rpx solid #176b5b;
  border-radius: 8rpx;
  color: #176b5b;
  font-size: 28rpx;
  font-weight: 700;
}

.button-primary.btn-busy,
.button-secondary.btn-busy,
.gov-btn.btn-busy,
.admin-action-btn.btn-busy,
.cloud-bar-action.btn-busy,
.gov-search-btn.btn-busy,
.btn-ghost.btn-busy {
  opacity: 0.65;
  pointer-events: none;
}

.empty {
  padding: 60rpx 24rpx;
  text-align: center;
  color: #68717d;
}

.required {
  margin-left: 4rpx;
  color: #d64545;
}

.guest-avatar-img {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  flex: none;
  background: #e8ecf0;
}

.guest-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 800;
  color: #68717d;
  line-height: 1;
}

.guest-avatar-img.gate-avatar {
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto 24rpx;
  display: block;
}

.auth-gate {
  margin-top: 80rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.auth-gate-icon {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: #e9f5f1;
  color: #176b5b;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 96rpx;
}

.auth-gate-title {
  margin-top: 24rpx;
  font-size: 36rpx;
  font-weight: 900;
  color: #17212b;
}

.auth-gate-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #68717d;
}

.limited-banner {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  background: #fff8ef;
  border: 2rpx solid #ffe2bf;
}

.limited-banner-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #8a4f12;
}

.limited-banner-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #68717d;
}

.limited-banner-link {
  margin-top: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #176b5b;
}

.limited-banner.private-banner {
  background: #f3f6f8;
  border-color: #d5e0e8;
}

.limited-banner.private-banner .limited-banner-title {
  color: #3d5a80;
}

.limited-line {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #8a4f12;
}

.auth-gate-btn {
  margin-top: 32rpx;
}

.detail-head-tags,
.type-wrap {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.publisher-badge {
  display: inline-flex;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.publisher-badge.publisher-card {
  background: #eef3ff;
  color: #3b5ccc;
}

.publisher-badge.publisher-license {
  background: #e9f5f1;
  color: #176b5b;
}

.publisher-badge.proxy-publish,
.pool-card-v2-badge.proxy-publish {
  background: #f3eefc;
  color: #5b3aa8;
}

.tag.proxy-publish-tag {
  background: #f3eefc;
  color: #5b3aa8;
}

.cert-image-block {
  margin-bottom: 20rpx;
}

.cert-image-label {
  margin-bottom: 10rpx;
  color: #47515c;
  font-size: 26rpx;
  font-weight: 700;
}

.cert-image-missing {
  padding: 28rpx 24rpx;
  border-radius: 12rpx;
  background: #f5f7fa;
  color: #68717d;
  font-size: 26rpx;
  line-height: 1.5;
}

.cert-image {
  width: 100%;
  height: 320rpx;
  border-radius: 8rpx;
  background: #eef1f4;
}

.party-card {
  margin-bottom: 16rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #f8fafc;
}

.party-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.party-side {
  font-size: 24rpx;
  font-weight: 800;
  color: #176b5b;
}

.party-role {
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  background: #e9f5f1;
  color: #176b5b;
  font-size: 22rpx;
}

.party-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #17212b;
}

.party-meta {
  margin-top: 6rpx;
  color: #68717d;
  font-size: 24rpx;
}

.party-summary {
  margin-top: 10rpx;
  color: #47515c;
  font-size: 26rpx;
  line-height: 1.5;
}

.close-demand-btn {
  margin-bottom: 16rpx;
}

.tag.success {
  background: #e8f8ef;
  color: #27ae60;
}

.tag.pending {
  background: #f0f2f5;
  color: #68717d;
}

.tag.demand {
  background: #eef3ff;
  color: #3b5ccc;
}

.level-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 700;
  background: #e9f5f1;
  color: #176b5b;
}

.level-badge.guest {
  background: #f0f2f5;
  color: #68717d;
}

.level-badge.logged {
  background: #eef3ff;
  color: #3b5ccc;
}

.level-badge.verified {
  background: #e9f5f1;
  color: #176b5b;
}

.match-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 22rpx;
  color: #68717d;
  font-weight: 600;
}

.match-strong {
  color: #176b5b;
  font-size: 24rpx;
  font-weight: 800;
}

.match-bar {
  width: 80rpx;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  overflow: hidden;
}

.match-fill {
  height: 100%;
  background: #176b5b;
  border-radius: 4rpx;
}

.verify-line-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.verify-line-row-end {
  justify-content: flex-end;
}

.pool-card-note {
  color: #8a4f12;
  font-size: 24rpx;
  font-weight: 700;
}

.bulletin-card {
  border-left: 6rpx solid #176b5b;
}

.bulletin-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #68717d;
}

.permission-card {
  margin: 20rpx 24rpx 0;
  padding: 24rpx 28rpx;
}

.permission-title {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #68717d;
}

.permission-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #176b5b 0%, #0f4d42 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
  box-shadow: 0 12rpx 36rpx rgba(23, 107, 91, 0.35);
  z-index: 50;
}

.page-tab .fab,
.pool-page .fab {
  bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.fab:active {
  transform: scale(0.95);
}

.fab-guest {
  opacity: 0.85;
}

.guest-locked-simple {
  padding: 28rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #68717d;
  background: #f8fafc;
  border: 2rpx dashed #d8dee4;
}

.guest-auth-card {
  margin-bottom: 16rpx;
  padding: 56rpx 36rpx 48rpx;
  text-align: center;
  border-radius: 20rpx;
}

.guest-auth-avatar {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.guest-auth-avatar-img {
  width: 128rpx;
  height: 128rpx;
}

.guest-auth-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #17212b;
}

.guest-auth-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #68717d;
}

.guest-auth-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-top: 32rpx;
}

.guest-auth-btn {
  flex: 1;
  max-width: 240rpx;
  height: 80rpx;
  font-size: 28rpx;
}

.guest-tip {
  text-align: center;
  background: linear-gradient(135deg, #fff8ef 0%, #fff3e0 100%);
  border: 2rpx solid #ffe2bf;
}

.guest-permission-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  background: #f8fafc;
}

.guest-permission-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #47515c;
  margin-bottom: 12rpx;
}

.guest-permission-text {
  font-size: 24rpx;
  line-height: 1.8;
  color: #68717d;
}

.onboard-hero {
  padding: 24rpx 8rpx 32rpx;
  text-align: center;
}

.onboard-logo {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #176b5b 0%, #0f4d42 100%);
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 96rpx;
}

.onboard-title {
  margin-top: 24rpx;
  font-size: 40rpx;
  font-weight: 900;
  color: #17212b;
}

.onboard-sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #68717d;
}

.permission-hint-card {
  margin-top: 48rpx;
  padding: 28rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 2rpx dashed #e8ecf0;
}

.permission-hint-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #47515c;
  margin-bottom: 12rpx;
}

.permission-hint-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: #68717d;
}

.sort-row-inline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.sort-tabs {
  display: flex;
  gap: 12rpx;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  padding-bottom: 4rpx;
  margin-bottom: 12rpx;
}

.filter-chip {
  flex-shrink: 0;
  padding: 12rpx 26rpx;
  border-radius: 40rpx;
  border: 2rpx solid #e8ecf0;
  background: #ffffff;
  font-size: 24rpx;
  color: #47515c;
}

.filter-chip.active {
  background: #176b5b;
  border-color: #176b5b;
  color: #ffffff;
  font-weight: 700;
}

.search-box {
  position: relative;
  margin-bottom: 16rpx;
  padding: 0 20rpx 0 64rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(23, 33, 43, 0.05);
}

.search-icon {
  position: absolute;
  left: 22rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #68717d;
}

.search-box input {
  height: 80rpx;
  color: #17212b;
  font-size: 28rpx;
}

/* 列表卡片（首页 + 池页共用） */
.opportunity-head,
.list-card .topline {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  justify-content: space-between;
}

.opportunity-title,
.list-card .title {
  flex: 1;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #17212b;
}

.opportunity-type,
.list-card .type {
  flex: none;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: #eef3f6;
  color: #47515c;
  font-size: 22rpx;
  font-weight: 600;
}

.opportunity-type.demand,
.list-card .type.demand {
  background: #fff1df;
  color: #8a4f12;
}

.opportunity-summary,
.list-card .summary {
  margin-top: 14rpx;
  color: #47515c;
  font-size: 26rpx;
  line-height: 1.55;
}

.tag-wrap,
.list-card .tag-line {
  margin-top: 14rpx;
}

.opportunity-meta,
.list-card .meta {
  margin-top: 10rpx;
  color: #68717d;
  font-size: 24rpx;
}

.verify-line {
  margin-top: 12rpx;
  color: #176b5b;
  font-size: 24rpx;
  font-weight: 700;
}

.opportunity.card,
.list-card {
  border-radius: 16rpx;
}

.opportunity.card:active,
.list-card:active {
  opacity: 0.96;
}

.status-badge {
  display: inline-flex;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status-pending {
  background: #fff8ef;
  color: #8a4f12;
}

.status-pending-mine {
  background: #fff0e8;
  color: #c2410c;
}

.status-pending-other {
  background: #eef3f8;
  color: #3d5a80;
}

.status-pending-platform {
  background: #f5f0ff;
  color: #6b4c9a;
}

.status-approved {
  background: #e9f5f1;
  color: #176b5b;
}

.status-closed {
  background: #eef1f4;
  color: #68717d;
}

.tag.warning {
  background: #fff8ef;
  color: #8a4f12;
}

.tag.danger {
  background: #fdecea;
  color: #c0392b;
}

.tag.resource {
  background: #e9f5f1;
  color: #176b5b;
}

.record-timeline {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 20rpx 0;
  font-size: 22rpx;
  color: #47515c;
}

.record-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #d8dee4;
  flex: none;
}

.record-dot.done {
  background: #176b5b;
}

.record-dot.pending {
  background: #8a4f12;
}

.record-timeline-sep {
  color: #d8dee4;
}

.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  padding: 0 28rpx;
  border: 2rpx solid #e8ecf0;
  border-radius: 8rpx;
  background: #ffffff;
  color: #17212b;
  font-size: 26rpx;
  font-weight: 700;
}

.btn-ghost.danger {
  color: #c0392b;
  border-color: #fdecea;
}

.record-actions {
  display: flex;
  gap: 16rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eef1f4;
  font-size: 26rpx;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-row .label {
  flex: none;
  color: #68717d;
}

.detail-row .value {
  text-align: right;
  font-weight: 600;
  color: #17212b;
}

.connect-reason-box {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 16rpx 0;
  font-size: 24rpx;
}

.connect-reason-title {
  font-weight: 700;
  margin-bottom: 8rpx;
  color: #17212b;
}

.fixed-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 2rpx solid #e8ecf0;
  z-index: 100;
}

.fixed-bottom-bar .button-primary,
.fixed-bottom-bar .button-secondary {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
}

.has-fixed-bar,
.has-bottom-bar {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.detail-page.has-fixed-bar,
.detail-page.has-bottom-bar {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ===== 资源池 / 需求池共用布局 ===== */
.pool-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.pool-page .auth-gate {
  margin-top: 48rpx;
  padding-top: 32rpx;
}

/* 查询区域 */
.pool-query-zone {
  flex: none;
}

.pool-query-card {
  padding: 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(23, 33, 43, 0.05);
}

.pool-query-card .search-box {
  margin-bottom: 0;
  box-shadow: none;
  padding-left: 64rpx;
  padding-right: 16rpx;
  border-radius: 12rpx;
  background: #f5f7fa;
}

.pool-filters {
  margin-top: 16rpx;
}

.filter-label {
  margin: 16rpx 0 10rpx;
  color: #68717d;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.filter-scroll {
  width: 100%;
  margin-bottom: 12rpx;
}

.filter-scroll-inner {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.filter-more-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 8rpx;
  padding: 12rpx 0;
  color: #176b5b;
  font-size: 24rpx;
  font-weight: 600;
}

.filter-more-arrow {
  font-size: 20rpx;
}

.favorite-btn {
  flex: none;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f7fa;
  border: 2rpx solid #e8ecf0;
}

.favorite-btn.active {
  background: #fff8ef;
  border-color: #f0c060;
}

.favorite-glyph {
  font-size: 32rpx;
  line-height: 1;
  color: #68717d;
}

.favorite-btn.active .favorite-glyph {
  color: #d48806;
}

/* 列表区域 */
.pool-list-zone {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(23, 33, 43, 0.05);
  overflow: hidden;
}

.pool-list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 20rpx;
  border-bottom: 2rpx solid #f0f2f5;
  background: #fafbfc;
}

.pool-list-header .result-count {
  color: #68717d;
  font-size: 24rpx;
}

.pool-list-header .sort-tabs {
  display: flex;
  gap: 20rpx;
}

.pool-list-header .sort {
  color: #68717d;
  font-size: 24rpx;
  padding-bottom: 4rpx;
}

.pool-list-header .sort.active {
  color: #176b5b;
  font-weight: 700;
  border-bottom: 4rpx solid #176b5b;
}

.pool-list-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 16rpx;
  min-height: 0;
}

.pool-list-body:not(.is-empty) {
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
}

.pool-list-body .list-card {
  margin-bottom: 12rpx;
  box-shadow: none;
  border: 2rpx solid #f0f2f5;
}

.pool-list-body .list-card:last-child {
  margin-bottom: 0;
}

.pool-list-body .empty {
  padding: 48rpx 24rpx 56rpx;
}

.pool-list-body.is-empty .empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 40rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.verify-trailing {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: none;
}

.connect-quick {
  flex: none;
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  background: #fff4e5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.connect-quick:active {
  opacity: 0.82;
}

.connect-quick-glyph {
  color: #b45309;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
}

.connect-quick-done {
  background: #e9f5f1;
}

.connect-quick-glyph-done {
  color: #176b5b;
  font-size: 22rpx;
}

.pool-list-body .list-card-viewed {
  border-color: #e8ebee;
}

.pool-list-body .list-card-applied {
  border-color: #c9e3db;
}

.pool-list-body .type-wrap .type,
.pool-list-body .type-wrap .browse-status,
.pool-list-body .type-wrap .publisher-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.2;
  flex: none;
}

.pool-list-body .tag-line .tag {
  padding: 6rpx 12rpx;
  font-size: 22rpx;
  line-height: 1.2;
  margin-bottom: 0;
}

.browse-status {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.2;
  flex: none;
}

.browse-status-viewed {
  background: #eef1f4;
  color: #68717d;
}

.browse-status-applied {
  background: #e9f5f1;
  color: #176b5b;
}

.list-card .small {
  margin-top: 16rpx;
  height: 72rpx;
  font-size: 26rpx;
}

.auth-gate-link {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #68717d;
  text-align: center;
}

.auth-gate-link .link-text {
  color: #176b5b;
  font-weight: 700;
}

/* ===== 资源池 / 需求池 · 方案 A ===== */
.pool-v2-toolbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pool-v2-toolbar .search-box {
  flex: 1;
  min-width: 0;
  margin-bottom: 0;
}

.pool-v2-filter-btn {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #e8ecf0;
  font-size: 24rpx;
  font-weight: 700;
  color: #17212b;
  line-height: 1;
}

.pool-v2-filter-btn.has-active {
  background: #e9f5f1;
  border-color: #b8ddd3;
  color: #176b5b;
}

.pool-v2-type-row {
  margin-top: 0;
}

.pool-v2-filter-label {
  margin-top: 16rpx;
  margin-bottom: 8rpx;
}

.pool-v2-filter-label:first-of-type {
  margin-top: 12rpx;
}

.pool-v2-quick-row {
  margin-bottom: 4rpx;
}

.pool-v2-list-toolbar {
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 2rpx solid #e8ecf0;
}

.pool-v2-result-count {
  font-size: 26rpx;
  color: #68717d;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.pool-v2-sort-track {
  display: flex;
  gap: 8rpx;
  padding: 6rpx;
  background: #f5f7fa;
  border-radius: 14rpx;
}

.pool-v2-sort-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 12rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #68717d;
  line-height: 1.2;
}

.pool-v2-sort-item.active {
  background: #ffffff;
  color: #176b5b;
  box-shadow: 0 2rpx 10rpx rgba(23, 33, 43, 0.06);
}

.pool-v2-list-header {
  display: none;
}

.pool-v2-sort {
  display: none;
}

.pool-card-v2 {
  position: relative;
  overflow: hidden;
  padding: 24rpx 24rpx 20rpx 28rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 2rpx solid #e8ecf0;
  box-shadow: 0 4rpx 16rpx rgba(23, 33, 43, 0.04);
}

.pool-card-v2::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: #176b5b;
}

.pool-card-v2-demand::before {
  background: #d48806;
}

.pool-card-v2-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.pool-card-v2-meta-left {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  min-width: 0;
  flex: 1;
}

.pool-card-v2-type {
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #e9f5f1;
  color: #176b5b;
}

.pool-card-v2-demand .pool-card-v2-type {
  background: #fff8ef;
  color: #8a4f12;
}

.pool-card-v2-badge {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  background: #eef8f4;
  color: #176b5b;
}

.pool-card-v2-status {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  background: #f0f2f5;
  color: #68717d;
}

.pool-card-v2-status.applied {
  background: #e9f5f1;
  color: #176b5b;
}

.pool-card-v2-star {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f7fa;
  border: 2rpx solid #e8ecf0;
  flex-shrink: 0;
}

.pool-card-v2-star.active {
  background: #fff8ef;
  border-color: #f0c060;
}

.pool-card-v2-star .favorite-glyph {
  font-size: 32rpx;
  color: #68717d;
  line-height: 1;
}

.pool-card-v2-star.active .favorite-glyph {
  color: #d48806;
}

.pool-card-v2-title {
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.4;
  color: #17212b;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.pool-card-v2-facts {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 20rpx;
  margin-bottom: 12rpx;
}

.pool-card-v2-fact {
  font-size: 24rpx;
  color: #47515c;
  line-height: 1.3;
}

.pool-card-v2-summary {
  font-size: 26rpx;
  line-height: 1.45;
  color: #68717d;
  margin-bottom: 16rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pool-card-v2-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f2f5;
}

.pool-card-v2-time {
  font-size: 22rpx;
  color: #68717d;
  flex: 1;
  min-width: 0;
}

.pool-card-v2-link {
  font-size: 24rpx;
  font-weight: 700;
  color: #176b5b;
  flex-shrink: 0;
}

.pool-card-v2-action {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: #176b5b;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  flex-shrink: 0;
}

.pool-card-v2-action.done {
  background: #e9f5f1;
  color: #176b5b;
}

.pool-drawer-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(16, 24, 32, 0.45);
  z-index: 200;
}

.pool-drawer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 201;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  transform: translateY(110%);
  transition: transform 0.25s ease;
  max-height: 72vh;
  overflow-y: auto;
}

.pool-drawer.open {
  transform: translateY(0);
}

.pool-drawer-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.pool-drawer-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #17212b;
}

.pool-drawer-close {
  font-size: 28rpx;
  color: #68717d;
  padding: 8rpx;
}

.pool-drawer-foot {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f2f5;
}

.pool-drawer-reset {
  flex: 1;
  text-align: center;
  padding: 22rpx;
  border-radius: 12rpx;
  background: #f5f7fa;
  color: #47515c;
  font-size: 28rpx;
  font-weight: 700;
}

.pool-drawer-apply {
  flex: 2;
  text-align: center;
  padding: 22rpx;
  border-radius: 12rpx;
  background: #176b5b;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.pool-card-v2-compact {
  margin-bottom: 12rpx;
  padding: 20rpx 20rpx 16rpx 24rpx;
}

.pool-card-v2-compact .pool-card-v2-title {
  font-size: 28rpx;
  -webkit-line-clamp: 1;
}

.pool-card-v2-compact .pool-card-v2-summary {
  margin-bottom: 12rpx;
}

/* 待办引导（首页 / 我的 共用） */
.next-step {
  margin-bottom: 0;
  padding: 28rpx;
  border: 2rpx solid #b8dfd4;
  background: linear-gradient(135deg, #e9f5f1 0%, #d4ede6 100%);
}

.next-step-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.next-step-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f4d42;
}

.next-step-action {
  flex: none;
  color: #176b5b;
  font-size: 26rpx;
  font-weight: 700;
}

.next-step-hint {
  margin-top: 10rpx;
  color: #47515c;
  font-size: 24rpx;
  line-height: 1.5;
}

.next-step.urgent {
  border-color: #ffd2a1;
  background: linear-gradient(135deg, #fff8ef 0%, #ffedd5 100%);
}

.next-step.urgent .next-step-title {
  color: #b45309;
}

.next-step.urgent .next-step-action {
  color: #b45309;
}

.detail-page .related-card {
  margin: 0 24rpx 16rpx;
}

@keyframes list-item-slide-up {
  from {
    opacity: 0;
    transform: translateY(28rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.list-item-enter {
  animation: list-item-slide-up 0.38s cubic-bezier(0.22, 1, 0.36, 1) both;
}
