@import "../admin/admin.wxss";

.admin-gov-page {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.gov-tabs {
  display: flex;
  margin-bottom: 24rpx;
  padding: 8rpx;
}

.gov-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #68717d;
  border-radius: 12rpx;
}

.gov-tab.active {
  background: #e8f5f1;
  color: #176b5b;
  font-weight: 600;
}

.gov-toolbar {
  margin-bottom: 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.gov-search-input {
  flex: 1;
  min-height: 72rpx;
  padding: 0 16rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.gov-search-btn {
  color: #176b5b;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 8rpx;
}

.gov-filter-row {
  margin-top: 16rpx;
}

.gov-empty {
  padding: 48rpx 32rpx;
  text-align: center;
}

.gov-empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #101820;
}

.gov-empty-text {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #68717d;
}

.gov-item {
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.gov-item-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.gov-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #e8f5f1;
  color: #176b5b;
}

.gov-tag.resource {
  background: #eef4ff;
  color: #2f5fd0;
}

.gov-tag.demand {
  background: #fff4e8;
  color: #b86b00;
}

.gov-tag.muted {
  background: #f0f2f5;
  color: #68717d;
}

.gov-item-id {
  font-size: 22rpx;
  color: #9aa3ad;
}

.gov-item-title {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #101820;
}

.gov-item-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #68717d;
}

.gov-item-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.gov-btn {
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.gov-btn.ghost {
  background: #f5f7fa;
  color: #101820;
}

.gov-btn.primary {
  background: #176b5b;
  color: #fff;
}

.gov-btn.danger {
  background: #fff1f0;
  color: #c0392b;
}

.gov-user-card {
  padding: 24rpx;
}

.gov-user-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
  font-size: 28rpx;
}

.gov-user-label {
  color: #68717d;
}

.gov-user-value {
  color: #101820;
  text-align: right;
  flex: 1;
}

.danger-text {
  color: #c0392b;
  font-weight: 600;
}

.ok-text {
  color: #176b5b;
  font-weight: 600;
}

.gov-user-reason,
.gov-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
}
