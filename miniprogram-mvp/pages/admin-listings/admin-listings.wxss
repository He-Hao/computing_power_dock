@import "../admin-governance/admin-governance.wxss";

.admin-listings-page {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.gov-search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  position: static;
  margin-bottom: 0;
  padding: 0;
  background: transparent;
  box-shadow: none;
}

.gov-search-field {
  position: relative;
  flex: 1;
  min-width: 0;
  padding: 0 16rpx 0 56rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.gov-search-field .search-icon {
  position: absolute;
  left: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  font-weight: 700;
  color: #68717d;
  line-height: 1;
}

.gov-search-box .gov-search-input {
  flex: none;
  width: 100%;
  min-height: 72rpx;
  padding: 0;
  background: transparent;
  border-radius: 0;
  font-size: 28rpx;
}

.listing-card {
  margin-bottom: 20rpx;
}

.listing-status {
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.listing-status.published {
  background: #e9f5f1;
  color: #176b5b;
}

.listing-status.closed {
  background: #f3f4f6;
  color: #68717d;
}

.listing-status.pending {
  background: #fff4e5;
  color: #b26a00;
}
