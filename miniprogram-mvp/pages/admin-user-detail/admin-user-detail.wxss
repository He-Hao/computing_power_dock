@import "../admin-governance/admin-governance.wxss";

.admin-user-detail-page {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.user-hero-card {
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.user-hero-phone {
  font-size: 36rpx;
  font-weight: 700;
  color: #101820;
}

.user-hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.user-hero-subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #68717d;
  line-height: 1.5;
}

.section-title.compact {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #101820;
}

.user-action-card {
  margin-top: 20rpx;
}

.gov-tag.danger {
  background: #fff1f0;
  color: #c0392b;
}

.cert-image-block {
  margin-top: 16rpx;
}

.cert-image-label {
  margin-bottom: 8rpx;
  color: #68717d;
  font-size: 24rpx;
}

.cert-image-loading {
  margin-bottom: 12rpx;
  color: #176b5b;
  font-size: 24rpx;
}

.cert-image-error {
  margin-bottom: 12rpx;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  background: #fff4ec;
  color: #8a4f12;
  font-size: 24rpx;
  line-height: 1.5;
}

.cert-image-missing {
  padding: 28rpx 24rpx;
  border-radius: 12rpx;
  background: #f5f7fa;
  color: #68717d;
  font-size: 26rpx;
  line-height: 1.5;
}

.cert-image {
  width: 100%;
  height: 320rpx;
  border-radius: 8rpx;
  background: #eef1f4;
}
