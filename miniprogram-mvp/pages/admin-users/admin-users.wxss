@import "../admin-governance/admin-governance.wxss";

.admin-users-page {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.gov-search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  position: static;
  margin-bottom: 0;
  padding: 0;
  background: transparent;
  box-shadow: none;
}

.gov-search-field {
  position: relative;
  flex: 1;
  min-width: 0;
  padding: 0 16rpx 0 56rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.gov-search-field .search-icon {
  position: absolute;
  left: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #68717d;
  line-height: 1;
}

.gov-search-box .gov-search-input {
  flex: none;
  width: 100%;
  min-height: 72rpx;
  padding: 0;
  background: transparent;
  border-radius: 0;
  font-size: 28rpx;
}

.user-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.user-card-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 30rpx;
  font-weight: 700;
  color: #101820;
}

.user-card-contact {
  margin-top: 4rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #101820;
  line-height: 1.5;
}

.user-card-subtitle {
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #68717d;
  line-height: 1.5;
}

.user-card-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #68717d;
  line-height: 1.5;
}

.user-card-meta.muted {
  color: #9aa3ad;
}

.user-card-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f2f5;
  font-size: 24rpx;
}

.user-card-hint {
  color: #9aa3ad;
}

.user-card-action {
  color: #176b5b;
  font-weight: 600;
}

.gov-tag.danger {
  background: #fff1f0;
  color: #c0392b;
}
