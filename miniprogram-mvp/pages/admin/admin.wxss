.admin-page {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.admin-hero {
  margin-bottom: 20rpx;
  padding: 32rpx 28rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #101820 0%, #1a3a35 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(16, 24, 32, 0.18);
}

.admin-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.admin-kicker {
  color: #7bd7c0;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.admin-user {
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.3;
}

.admin-meta {
  margin-top: 6rpx;
  color: rgba(216, 225, 232, 0.85);
  font-size: 24rpx;
}

.admin-logout {
  flex: none;
  padding: 12rpx 20rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #d8e1e8;
  font-size: 24rpx;
  font-weight: 600;
}

.admin-stats {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding: 20rpx 0 4rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
}

.admin-stat {
  flex: 1;
  text-align: center;
}

.admin-stat-split {
  width: 2rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.12);
}

.admin-stat-value {
  color: #7bd7c0;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.1;
}

.admin-stat-label {
  margin-top: 8rpx;
  color: rgba(216, 225, 232, 0.8);
  font-size: 22rpx;
}

.admin-tabs {
  display: flex;
  gap: 10rpx;
  margin-bottom: 20rpx;
  padding: 6rpx;
  border-radius: 16rpx;
  background: #e8ecf0;
}

.admin-tab {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #68717d;
}

.admin-tab.active {
  background: #ffffff;
  color: #176b5b;
  font-weight: 800;
  box-shadow: 0 4rpx 12rpx rgba(23, 33, 43, 0.08);
}

.admin-empty {
  padding: 48rpx 32rpx 56rpx;
  text-align: center;
  border-radius: 16rpx;
  background: #ffffff;
}

.admin-empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #68717d;
  line-height: 1.4;
}

.admin-empty-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #9aa3ad;
}

.admin-item {
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
}

.admin-item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.admin-item-title {
  margin-top: 14rpx;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
  color: #17212b;
}

.admin-item-meta,
.admin-item-contact {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #68717d;
}

.admin-item-summary {
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  background: #f5f7fa;
  color: #47515c;
  font-size: 24rpx;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.admin-item-proxy-title {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.admin-item-time {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9aa3ad;
}

.admin-item-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f3f6;
}

.admin-action-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.admin-action-btn.ghost {
  background: #f5f7fa;
  color: #47515c;
}

.admin-action-btn.reject {
  background: #fff8ef;
  color: #8a4f12;
  border: 2rpx solid #ffe2bf;
}

.admin-action-btn.primary {
  background: #176b5b;
  color: #ffffff;
}

.tag.cert {
  background: #eef3ff;
  color: #3b5ccc;
}
