<view class="page change-password-page">
  <view class="change-password-body card">
    <view class="change-password-hint">为保障账号安全，新密码至少 8 位，且需同时包含字母与数字。</view>

    <view class="field-block">
      <view class="field-label">原密码<text class="required">*</text></view>
      <input
        class="text-input"
        value="{{oldPassword}}"
        bindinput="onOldPasswordInput"
        password
        maxlength="32"
        placeholder="请输入当前登录密码"
      />
    </view>

    <view class="field-block">
      <view class="field-label">新密码<text class="required">*</text></view>
      <input
        class="text-input"
        value="{{newPassword}}"
        bindinput="onNewPasswordInput"
        password
        maxlength="32"
        placeholder="至少 8 位，含字母与数字"
      />
      <view class="password-meter" wx:if="{{newPassword}}">
        <view class="password-meter-fill" style="width: {{passwordStrength.width}}%"></view>
      </view>
      <view class="form-hint" wx:if="{{newPassword}}">{{passwordStrength.text}}</view>
    </view>

    <view class="field-block">
      <view class="field-label">确认新密码<text class="required">*</text></view>
      <input
        class="text-input"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
        password
        maxlength="32"
        placeholder="再次输入新密码"
      />
    </view>

    <button
      class="action-btn primary"
      bindtap="submitChangePassword"
      loading="{{submitLoading}}"
      disabled="{{submitLoading}}"
    >
      确认修改
    </button>
  </view>
</view>
