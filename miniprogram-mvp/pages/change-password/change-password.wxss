.change-password-page {
  padding: 24rpx;
}

.change-password-body {
  padding: 28rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(23, 33, 43, 0.06);
}

.change-password-hint {
  margin-bottom: 24rpx;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  background: #f0f6f4;
  color: #3d5a52;
  font-size: 26rpx;
  line-height: 1.5;
}

.field-block {
  margin-bottom: 20rpx;
}

.field-label {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #17212b;
}

.required {
  color: #d64545;
}

.text-input {
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #dce3ea;
  border-radius: 8rpx;
  background: #ffffff;
  font-size: 32rpx;
  color: #17212b;
  box-sizing: border-box;
}

.password-meter {
  height: 8rpx;
  margin-top: 12rpx;
  border-radius: 4rpx;
  background: #e8ecf0;
  overflow: hidden;
}

.password-meter-fill {
  height: 100%;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #f0a020, #176b5b);
  transition: width 0.2s ease;
}

.form-hint {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #68717d;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100% !important;
  height: 88rpx;
  margin-top: 12rpx;
  padding: 0;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  border: none;
  background: #176b5b;
  color: #ffffff;
}

.action-btn[disabled] {
  opacity: 0.55;
}
