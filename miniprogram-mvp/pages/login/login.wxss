/* 根容器使用全局 .page */

.login-mode-tabs {
  display: flex;
  margin-bottom: 24rpx;
  padding: 6rpx;
  border-radius: 12rpx;
  background: #e8ecf0;
}

.login-mode-tab {
  flex: 1;
  height: 72rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #68717d;
}

.login-mode-tab.active {
  background: #ffffff;
  color: #176b5b;
  font-weight: 800;
  box-shadow: 0 4rpx 12rpx rgba(23, 33, 43, 0.08);
}

.login-body {
  padding: 28rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(23, 33, 43, 0.06);
}

.field-block {
  margin-bottom: 20rpx;
}

.field-label {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #17212b;
}

.text-input {
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #dce3ea;
  border-radius: 8rpx;
  background: #ffffff;
  font-size: 32rpx;
  color: #17212b;
  box-sizing: border-box;
}

.text-input-disabled {
  background: #f3f5f7;
  color: #68717d;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100% !important;
  height: 88rpx;
  margin-top: 12rpx;
  padding: 0;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  border: none;
  background: #176b5b;
  color: #ffffff;
}

.action-btn[disabled] {
  opacity: 0.55;
}

.register-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 28rpx;
}

.register-hint {
  font-size: 28rpx;
  color: #68717d;
}

.link-text {
  font-size: 28rpx;
  color: #176b5b;
  font-weight: 700;
}

.lock-tip {
  margin-bottom: 16rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #fff1df;
  color: #8a4f12;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.admin-login-hint {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #68717d;
}

.admin-notice {
  margin-top: 24rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.5;
  color: #68717d;
}

.admin-logged-label {
  color: #68717d;
  font-size: 24rpx;
  text-align: center;
}

.admin-logged-name {
  margin-top: 12rpx;
  text-align: center;
  color: #176b5b;
  font-size: 40rpx;
  font-weight: 900;
}

.admin-logged-meta {
  margin-top: 10rpx;
  margin-bottom: 8rpx;
  text-align: center;
  color: #47515c;
  font-size: 24rpx;
}

.admin-logout-btn {
  margin-top: 16rpx;
  border: 2rpx solid #176b5b !important;
  background: #ffffff !important;
  color: #176b5b !important;
}

.action-btn.disabled {
  opacity: 0.55;
}

.auth-context-card {
  margin-bottom: 20rpx;
  padding: 24rpx 28rpx;
  border-radius: 12rpx;
  border: 2rpx solid #b8dfd4;
  background: linear-gradient(135deg, #e9f5f1 0%, #d4ede6 100%);
}

.auth-context-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f4d42;
}

.auth-context-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #47515c;
}

.user-auth-tabs {
  display: flex;
  margin-bottom: 20rpx;
  padding: 6rpx;
  border-radius: 12rpx;
  background: #e8ecf0;
}

.user-auth-tab {
  flex: 1;
  height: 72rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #68717d;
}

.user-auth-tab.active {
  background: #ffffff;
  color: #176b5b;
  font-weight: 800;
  box-shadow: 0 4rpx 12rpx rgba(23, 33, 43, 0.08);
}

.user-auth-tab.disabled {
  color: #b0b8c0;
  opacity: 0.55;
}

.user-auth-tab.disabled.active {
  background: transparent;
  color: #b0b8c0;
  font-weight: 600;
  box-shadow: none;
}

.register-disabled-hint {
  margin: -8rpx 0 16rpx;
  font-size: 24rpx;
  color: #8a939d;
  text-align: center;
}

.register-panel {
  padding-bottom: 12rpx;
}

.required {
  margin-left: 4rpx;
  color: #c0392b;
}

.password-meter {
  height: 8rpx;
  margin-top: 12rpx;
  border-radius: 4rpx;
  background: #e8ecf0;
  overflow: hidden;
}

.password-meter-fill {
  height: 100%;
  background: #176b5b;
  border-radius: 4rpx;
}

.form-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #68717d;
}

.setup-hint {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 8rpx;
  background: #fff7e6;
  color: #ad6800;
  font-size: 24rpx;
  line-height: 1.6;
}

.block-title {
  margin: 8rpx 0 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #17212b;
}

.action-btn.secondary {
  border: 2rpx solid #176b5b;
  background: #ffffff;
  color: #176b5b;
}

.permission-hint-card {
  margin-top: 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(23, 33, 43, 0.06);
}

.permission-hint-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #17212b;
}

.permission-hint-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #68717d;
}

.login-agree-row {
  margin-top: 8rpx;
  margin-bottom: 4rpx;
  padding-top: 0;
  border-top: none;
}

.login-agree-text {
  font-size: 26rpx;
  line-height: 1.65;
}
