.onboard-page {
  padding-bottom: 48rpx;
}

.welcome-card {
  margin-bottom: 28rpx;
  padding: 12rpx 8rpx 0;
}

.welcome-kicker {
  margin-bottom: 12rpx;
  color: #176b5b;
  font-size: 26rpx;
  font-weight: 700;
}

.welcome-title {
  margin-bottom: 12rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #17212b;
}

.welcome-text {
  color: #68717d;
  font-size: 28rpx;
  line-height: 1.6;
}

.intent-list {
  margin-bottom: 24rpx;
}

.intent-card {
  position: relative;
  margin-bottom: 16rpx;
  padding: 28rpx 24rpx;
  border: 2rpx solid #e4e8ed;
  border-radius: 12rpx;
  background: #ffffff;
}

.intent-card.selected {
  border-color: #176b5b;
  background: #f3faf7;
}

.intent-title {
  margin-bottom: 8rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #17212b;
}

.intent-text {
  color: #68717d;
  font-size: 26rpx;
  line-height: 1.5;
}

.intent-check {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #176b5b;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 40rpx;
  text-align: center;
}

.level-tip {
  margin-bottom: 32rpx;
}

.level-tip-title {
  margin-bottom: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #17212b;
}

.level-tip-row {
  margin-bottom: 8rpx;
  color: #68717d;
  font-size: 24rpx;
  line-height: 1.5;
}

.onboard-btn {
  margin-bottom: 20rpx;
}

.skip-link {
  text-align: center;
  color: #68717d;
  font-size: 26rpx;
}
