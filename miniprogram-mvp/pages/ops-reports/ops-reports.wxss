@import "../ops-proxy/ops-proxy.wxss";

.ops-reports-page {
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.report-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.report-card-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.report-card-time {
  margin-left: auto;
  font-size: 22rpx;
  color: #8a939c;
}

.report-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #17212b;
  margin-bottom: 8rpx;
}

.report-card-meta {
  font-size: 24rpx;
  color: #68717d;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.report-card-reason {
  font-size: 24rpx;
  color: #c0392b;
  margin-bottom: 8rpx;
}

.report-card-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.report-action-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 10rpx;
  font-size: 26rpx;
}

.report-action-btn.ghost {
  background: #f0f3f6;
  color: #17212b;
}

.report-action-btn.reject {
  background: #fdecea;
  color: #c0392b;
}

.report-action-btn.primary {
  background: #176b5b;
  color: #fff;
}
