.record-page {
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.connect-pending-banner {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
  padding: 20rpx 22rpx;
  border-radius: 14rpx;
  border: 2rpx solid transparent;
}

.connect-pending-banner.mine {
  background: #fff0e8;
  border-color: #ffd8c7;
}

.connect-pending-banner.other {
  background: #eef3f8;
  border-color: #d5e3f0;
}

.connect-pending-banner.platform {
  background: #f5f0ff;
  border-color: #e4d8f8;
}

.connect-pending-banner-label {
  font-size: 30rpx;
  font-weight: 800;
}

.connect-pending-banner.mine .connect-pending-banner-label {
  color: #c2410c;
}

.connect-pending-banner.other .connect-pending-banner-label {
  color: #3d5a80;
}

.connect-pending-banner.platform .connect-pending-banner-label {
  color: #6b4c9a;
}

.connect-pending-banner-hint {
  font-size: 24rpx;
  line-height: 1.5;
  color: #47515c;
}

.connect-pending-banner.mine .connect-pending-banner-hint {
  color: #9a3412;
}

.connect-pending-banner.other .connect-pending-banner-hint {
  color: #3d5a80;
}

.connect-pending-banner.platform .connect-pending-banner-hint {
  color: #6b4c9a;
}

.form-tip {
  margin-bottom: 16rpx;
  color: #68717d;
  font-size: 24rpx;
  line-height: 1.5;
}

.attachment-list {
  margin-bottom: 12rpx;
}

.attachment-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  padding: 16rpx;
  border: 2rpx solid #e8ecf0;
  border-radius: 12rpx;
  background: #fafbfc;
}

.attachment-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.attachment-thumb {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  flex: none;
  background: #eef1f4;
}

.attachment-file {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  background: #eef3f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex: none;
}

.attachment-name {
  flex: 1;
  color: #17212b;
  font-size: 26rpx;
  line-height: 1.4;
  word-break: break-all;
}

.attachment-remove {
  flex: none;
  color: #d64545;
  font-size: 24rpx;
  font-weight: 700;
}

.attachment-add {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  border: 2rpx dashed #c5d0d8;
  border-radius: 12rpx;
  color: #176b5b;
  font-size: 28rpx;
  font-weight: 700;
  background: #f8fbfa;
}

.attachment-add-icon {
  font-size: 36rpx;
  line-height: 1;
}

.attachment-save {
  margin-top: 16rpx;
  height: 72rpx;
  font-size: 28rpx;
}

.record-page.has-fixed-bar {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.hero-card {
  padding: 36rpx 28rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #101820 0%, #1a3a35 100%);
  color: #ffffff;
  margin-bottom: 20rpx;
}

.hero-card.light {
  background: #ffffff;
  color: #17212b;
  box-shadow: 0 8rpx 24rpx rgba(23, 33, 43, 0.06);
}

.hero-kicker-sm {
  font-size: 22rpx;
  opacity: 0.75;
  margin-bottom: 8rpx;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.3;
}

.hero-status {
  display: inline-flex;
  margin-top: 16rpx;
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-card.light .hero-status {
  background: #fff8ef;
  color: #8a4f12;
}

.hero-card .hero-status.status-pending {
  background: #fff8ef;
  color: #8a4f12;
}

.hero-card .hero-status.status-pending-mine {
  background: #fff0e8;
  color: #c2410c;
}

.hero-card .hero-status.status-pending-other {
  background: #eef3f8;
  color: #3d5a80;
}

.hero-card .hero-status.status-pending-platform {
  background: #f5f0ff;
  color: #6b4c9a;
}

.hero-card .hero-status.status-approved {
  background: #e9f5f1;
  color: #176b5b;
}

.hero-card .hero-status.status-closed {
  background: #eef1f4;
  color: #68717d;
}

.hero-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.55;
  opacity: 0.85;
}

.hero-card.light .hero-text {
  color: #68717d;
  opacity: 1;
}

.hero-time {
  margin-top: 16rpx;
  font-size: 22rpx;
  opacity: 0.65;
}

.confirm-banner {
  background: #e9f5f1;
  border-color: #b8dfd4;
  color: #0f4d42;
}

.compact {
  margin: 0 0 16rpx;
  font-size: 30rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef1f4;
  color: #17212b;
  font-size: 28rpx;
}

.row:last-child {
  border-bottom: none;
}

.label {
  flex: none;
  color: #68717d;
}

.desc,
.connect-reason {
  color: #47515c;
  font-size: 28rpx;
  line-height: 1.55;
}

.time {
  margin-top: 16rpx;
  color: #68717d;
  font-size: 24rpx;
}

.timeline-item {
  display: flex;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

.timeline-dot {
  width: 18rpx;
  height: 18rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: #176b5b;
  flex: none;
}

.timeline-dot.pending {
  background: #8a4f12;
}

.timeline-dot.muted {
  background: #d8dee4;
}

.timeline-status {
  font-size: 28rpx;
  font-weight: 800;
}

.timeline-hint {
  margin-top: 8rpx;
  color: #47515c;
  font-size: 26rpx;
  line-height: 1.5;
}

.timeline-time {
  margin-top: 8rpx;
  color: #68717d;
  font-size: 24rpx;
}

.publish-tip {
  color: #47515c;
  font-size: 26rpx;
  line-height: 1.5;
}

.listing-button {
  margin-top: 16rpx;
  height: 72rpx;
  font-size: 26rpx;
}

.connect-action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.connect-action-row .button-primary,
.connect-action-row .button-secondary {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
}

.connect-action-row .button-primary.full-width {
  flex: 1;
}

.success-page {
  text-align: center;
  padding: 48rpx 20rpx 32rpx;
}

.success-page .trade-id-line {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

.success-icon {
  width: 144rpx;
  height: 144rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: #e9f5f1;
  color: #176b5b;
  font-size: 72rpx;
  font-weight: 800;
  line-height: 144rpx;
}

.success-title {
  margin-top: 28rpx;
  font-size: 40rpx;
  font-weight: 900;
  color: #17212b;
}

.success-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #68717d;
}

.connect-success-listings .party-card + .party-card {
  margin-top: 16rpx;
}

.contact-reveal {
  margin-bottom: 16rpx;
  padding: 28rpx;
  border-radius: 12rpx;
  background: #e9f5f1;
  border: 2rpx solid #b8dfd4;
}

.contact-reveal.resource-side {
  background: #eef3ff;
  border-color: #c5d4f5;
}

.contact-reveal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.contact-reveal-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f4d42;
}

.contact-copy-btn {
  flex-shrink: 0;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #8ec9bb;
  color: #0f6b5c;
  font-size: 22rpx;
  font-weight: 700;
}

.contact-reveal.resource-side .contact-copy-btn {
  border-color: #a8bdef;
  color: #3b5ccc;
}

.contact-reveal.resource-side .contact-reveal-title {
  color: #3b5ccc;
}

.contact-line {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 10rpx 0;
  font-size: 26rpx;
  color: #17212b;
}

.contact-line text:first-child {
  color: #68717d;
}

.contact-line-value {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.contact-phone-text {
  text-align: right;
  word-break: break-all;
}

.contact-copy-link {
  flex-shrink: 0;
  color: #0f6b5c;
  font-size: 24rpx;
  font-weight: 700;
}

.contact-reveal.resource-side .contact-copy-link {
  color: #3b5ccc;
}

.next-tips {
  margin-bottom: 16rpx;
}

.connect-risk-notice {
  margin-bottom: 24rpx;
  background: #fff8f0;
  border: 2rpx solid #ffe2c7;
}

.connect-risk-notice .section-title {
  color: #c2410c;
}

.risk-notice-item {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #7c4a1a;
}

.risk-notice-item:first-of-type {
  margin-top: 0;
}

.tip-item {
  padding: 8rpx 0;
  font-size: 26rpx;
  color: #68717d;
}

.connect-next-step-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #eef1f4;
}

.connect-next-step-item:last-child {
  border-bottom: none;
}

.connect-next-step-item:active {
  opacity: 0.75;
}

.connect-next-step-icon {
  flex: none;
  font-size: 32rpx;
}

.connect-next-step-copy {
  flex: 1;
  min-width: 0;
}

.connect-next-step-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #17212b;
}

.connect-next-step-hint {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #68717d;
}

.connect-next-step-arrow {
  flex: none;
  color: #176b5b;
  font-size: 28rpx;
  font-weight: 700;
}

.rejection-resubmit-card {
  border: 2rpx solid #fecaca;
  background: #fff7f7;
}

.rejection-resubmit-hint {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #b91c1c;
  font-weight: 600;
}

.rejection-resubmit-tip {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #7f1d1d;
}

.rejection-resubmit-btn {
  margin-top: 20rpx;
}

.detail-desc {
  margin-top: 20rpx;
  color: #47515c;
  font-size: 26rpx;
  line-height: 1.6;
}

.linked-connects-card {
  margin-bottom: 20rpx;
}

.linked-connect-item {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e8ecf0;
  background: #fafbfc;
}

.linked-connect-item:active {
  background: #f0f2f5;
}

.linked-connect-item-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.linked-connect-item-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #17212b;
  line-height: 1.4;
}

.linked-pending-tag {
  display: inline-flex;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.linked-pending-tag.mine {
  background: #fff0e8;
  color: #c2410c;
}

.linked-pending-tag.other {
  background: #eef3f8;
  color: #3d5a80;
}

.linked-pending-tag.platform {
  background: #f5f0ff;
  color: #6b4c9a;
}

.linked-pending-hint {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 1.4;
}

.linked-connect-item-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
  margin-top: 8rpx;
  font-size: 22rpx;
}

.linked-action-tag {
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  background: #fff8ef;
  color: #b45309;
  font-size: 20rpx;
  font-weight: 700;
}

.linked-connect-item-summary {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.linked-connect-item-action {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #176b5b;
}

.party-card-link {
  border: 2rpx solid #e8f4f1;
}

.party-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.party-pool-tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #e8f4f1;
  color: #176b5b;
  font-size: 20rpx;
  font-weight: 700;
}

.party-title-link {
  color: #176b5b;
}

.party-listing-action {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #176b5b;
}

.listing-publish-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #47515c;
}

.listing-publish-card .public-display-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 16rpx;
  padding: 20rpx 22rpx;
  border-radius: 12rpx;
  background: #f8fafb;
  border: 2rpx solid #e8edf2;
}

.listing-publish-card .public-display-main {
  flex: 1;
  min-width: 0;
}

.listing-publish-card .public-display-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2933;
}

.listing-publish-card .public-display-tip {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #68717d;
}

.listing-preview-btn {
  margin-top: 4rpx;
}
