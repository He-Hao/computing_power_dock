<view class="page register-page">

  <view class="onboard-hero register-hero">

    <view class="onboard-title">创建账号</view>

    <view class="onboard-sub">填写基本信息，即可开始使用平台</view>

  </view>



  <view class="register-body">

    <view class="setup-hint" wx:if="{{cloudSetupHint}}">{{cloudSetupHint}}</view>

    <view class="field-block">

      <view class="field-label">姓名<text class="required">*</text></view>

      <input

        class="text-input"

        value="{{contact}}"

        bindinput="onContactInput"

        maxlength="20"

        placeholder="请输入真实姓名"

      />

    </view>

    <view class="field-block" wx:if="{{!useWechatPhoneAuth}}">

      <view class="field-label">手机号<text class="required">*</text></view>

      <input

        class="text-input"

        value="{{phone}}"

        bindinput="onPhoneInput"

        type="number"

        maxlength="11"

        placeholder="用于登录和接收通知"

      />

    </view>

    <view class="field-block">

      <view class="field-label">登录密码<text class="required">*</text></view>

      <input

        class="text-input"

        value="{{password}}"

        bindinput="onPasswordInput"

        password

        maxlength="32"

        placeholder="至少 8 位，含字母与数字"

      />

      <view class="password-meter" wx:if="{{password}}">

        <view class="password-meter-fill" style="width: {{passwordStrength.width}}%"></view>

      </view>

      <view class="form-hint" wx:if="{{password}}">{{passwordStrength.text}}</view>

    </view>

    <view class="field-block">

      <view class="field-label">确认密码<text class="required">*</text></view>

      <input

        class="text-input"

        value="{{confirmPassword}}"

        bindinput="onConfirmPasswordInput"

        password

        maxlength="32"

        placeholder="再次输入密码"

      />

    </view>

    <view class="block-title">{{disclaimerTitle}}</view>

    <scroll-view class="disclaimer-box" scroll-y>

      <view class="disclaimer-item" wx:for="{{disclaimerParagraphs}}" wx:key="*this">{{index + 1}}. {{item}}</view>

    </scroll-view>

    <view class="agree-row" bindtap="toggleDisclaimer">

      <view class="checkbox {{agreedDisclaimer ? 'checked' : ''}}"></view>

      <text class="agree-text">我已阅读并同意上述免责申明</text>

    </view>

  </view>



  <view class="register-footer">

    <button

      wx:if="{{useWechatPhoneAuth}}"

      class="action-btn secondary"

      open-type="getPhoneNumber"

      bindgetphonenumber="onGetPhoneNumber"

      loading="{{phoneLoading}}"

      disabled="{{!agreedDisclaimer || phoneLoading}}"

    >

      微信授权手机号

    </button>

    <button

      class="action-btn primary"

      bindtap="submitRegister"

      loading="{{submitLoading}}"

      disabled="{{!agreedDisclaimer || submitLoading || (useWechatPhoneAuth && !phoneVerified)}}"

    >

      注册并继续

    </button>

    <view class="link-row">

      <text class="link-text" bindtap="goLogin">已有账号？去登录</text>

    </view>

  </view>

</view>

