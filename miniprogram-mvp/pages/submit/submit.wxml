          <view class="field-label">型号/规格</view>
          <input value="{{form.specModel}}" data-field="specModel" bindinput="onInput" placeholder="例如：H800 80G / 8kW 高密机柜" />
        </view>
        <view class="field">
          <view class="field-label">租期/周期</view>
          <input value="{{form.cycle}}" data-field="cycle" bindinput="onInput" placeholder="例如：3 个月起租 / 按项目" />
        </view>
        <view class="field">
          <view class="field-label">交付方式</view>
          <picker mode="selector" range="{{deliveryOptions}}" bindchange="onDeliveryChange">
            <view class="picker-value">{{form.delivery || "请选择交付方式"}}</view>
          </picker>
        </view>
        <view class="field">
          <view class="field-label">交付周期</view>
          <input value="{{form.deliveryTime}}" data-field="deliveryTime" bindinput="onInput" placeholder="例如：7 天内开通 / 预约排期" />
        </view>
        <view class="field">
          <view class="field-label">网络/配套</view>
          <input value="{{form.networkSpec}}" data-field="networkSpec" bindinput="onInput" placeholder="例如：InfiniBand · 7×24 运维" />
